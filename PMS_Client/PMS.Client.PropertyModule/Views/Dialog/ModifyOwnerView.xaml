<UserControl x:Class="PMS.Client.PropertyModule.Views.Dialog.ModifyOwnerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PMS.Client.PropertyModule.Views.Dialog"
             xmlns:c="clr-namespace:PMS.Client.Common;assembly=PMS.Client.Common"
             mc:Ignorable="d" 
             Template="{DynamicResource DialogViewTemplate}"
             Height="650" Width="500">
    <UserControl.Resources>
        <c:SectionConverter x:Key="sConverter"/>
    </UserControl.Resources>

    <d:UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <FontFamily x:Key="AliFont">/PMS.Client.Assets;component/Fonts/AlibabaPuHuiTi-3-45-Light.ttf#阿里巴巴普惠体 3.0 45 Light</FontFamily>
                    <FontFamily x:Key="DyhFont">/PMS.Client.Assets;component/Fonts/SmileySans-Oblique.ttf#得意黑</FontFamily>
                    <FontFamily x:Key="Iconfont">/PMS.Client.Assets;component/Fonts/iconfont.ttf#zx_icons</FontFamily>

                    <DropShadowEffect Color="#3E7FFF" ShadowDepth="0" Opacity="0.2" x:Key="shadowEffect"/>
                </ResourceDictionary>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ViewTemplates.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ComboBoxStyle.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ViewTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </d:UserControl.Resources>
    <Grid Margin="40,20,40,10" TextBlock.Foreground="#888">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="85"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="85"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="85"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="业主信息" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="小区" Grid.Row="1" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="楼栋" Grid.Row="2" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="房间" Grid.Row="3" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="性别" Grid.Row="4" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="手机号" Grid.Row="5" VerticalAlignment="Top" Margin="0,8" Foreground="#888"/>
        <TextBlock Text="身份证号" Grid.Row="6" VerticalAlignment="Top" Margin="0,8" Foreground="#888"/>
        <TextBlock Text="身份证正面照" Grid.Row="7" VerticalAlignment="Top" Margin="0,8" Foreground="#888"/>
        <TextBlock Text="身份证反面照" Grid.Row="9" VerticalAlignment="Top" Margin="0,8" Foreground="#888"/>
        <TextBlock Text="备注" Grid.Row="11" VerticalAlignment="Top" Margin="0,8" Foreground="#888"/>


        <TextBox Grid.Column="1" Style="{DynamicResource NormalTextBoxStyle}" Height="30"
                 Text="{Binding OwnerInfo.HouseHolder, ValidatesOnDataErrors=True}"/>

        <ComboBox Grid.Column="1" Grid.Row="1" Height="30"
                  ItemsSource="{Binding QuarterList}"
                  DisplayMemberPath="Name"
                  SelectedItem="{Binding CurrentQuarter}"/>
        <ComboBox Grid.Column="1" Grid.Row="2" Height="30"
                  ItemsSource="{Binding BuildingList}"
                  DisplayMemberPath="Name"
                  SelectedItem="{Binding CurrentBuilding}"/>

        <TextBox Grid.Row="3" Grid.Column="1" Style="{DynamicResource NormalTextBoxStyle}" Height="30"
                    Text="{Binding OwnerInfo.RoomNum, ValidatesOnDataErrors=True}"/>

        <StackPanel Orientation="Horizontal" Grid.Row="4" Grid.Column="1"
                    VerticalAlignment="Center">
            <RadioButton Content="男"
            IsChecked="{Binding OwnerInfo.Gender,Converter={StaticResource sConverter},ConverterParameter=1}"/>
            <RadioButton Content="女" Margin="10,0"
            IsChecked="{Binding OwnerInfo.Gender,Converter={StaticResource sConverter},ConverterParameter=0}"/>
        </StackPanel>

        <TextBox Grid.Row="5" Grid.Column="1" Style="{DynamicResource NormalTextBoxStyle}" TextWrapping="Wrap" 
                 VerticalContentAlignment="Center" Padding="5,5"
                 Text="{Binding OwnerInfo.Phone, ValidatesOnDataErrors=True}"/>

        <TextBox Grid.Row="6" Grid.Column="1" Style="{DynamicResource NormalTextBoxStyle}" TextWrapping="Wrap" 
                 VerticalContentAlignment="Center" Padding="5,5"
                 Text="{Binding OwnerInfo.IdNumber, ValidatesOnDataErrors=True}"/>

        <Border Grid.Column="1" Grid.Row="7" Grid.RowSpan="2" HorizontalAlignment="Left"
                BorderBrush="#DDD" BorderThickness="2" Width="150" Height="100"
                CornerRadius="3">
            <Border.Background>
                <ImageBrush ImageSource="{Binding OwnerInfo.CredentialImg1}"/>
            </Border.Background>
        </Border>
        <TextBlock Grid.Row="7" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
            <Hyperlink Command="{Binding SelectCommand}" CommandParameter="1">选择</Hyperlink>
        </TextBlock>
        <Border Grid.Column="1" Grid.Row="9" Grid.RowSpan="2" HorizontalAlignment="Left"
                BorderBrush="#DDD" BorderThickness="2" Width="150" Height="100"
                CornerRadius="3">
            <Border.Background>
                <ImageBrush ImageSource="{Binding OwnerInfo.CredentialImg2}"/>
            </Border.Background>
        </Border>
        <TextBlock Grid.Row="9" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
            <Hyperlink Command="{Binding SelectCommand}" CommandParameter="2">选择</Hyperlink>
        </TextBlock>

        <TextBox Grid.Row="11" Grid.Column="1" Style="{DynamicResource NormalTextBoxStyle}" TextWrapping="Wrap" Margin="0,5"
                 VerticalContentAlignment="Top" Padding="5,5"
                 Text="{Binding OwnerInfo.Description}"/>
    </Grid>
</UserControl>
