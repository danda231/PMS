<UserControl x:Class="PMS.Client.FinanceModule.Views.Dialogs.ModifyIEDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PMS.Client.FinanceModule.Views.Dialogs"
             xmlns:c="clr-namespace:PMS.Client.Common;assembly=PMS.Client.Common"
             Template="{DynamicResource DialogViewTemplate}"
             mc:Ignorable="d" 
             Height="480" Width="450">
    <UserControl.Resources>
        <c:SectionConverter x:Key="sConverter"/>
    </UserControl.Resources>
    <Grid Margin="40,20,40,10" TextBlock.Foreground="#888">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="记账类型" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="收支类型" Grid.Row="1" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="账款发生日期" Grid.Row="2" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="金额" Grid.Row="3" VerticalAlignment="Center" Margin="0,8" Foreground="#888"/>
        <TextBlock Text="摘要" Grid.Row="4" VerticalAlignment="Center" Margin="0,8" Foreground="#888"/>
        <TextBlock Text="所属项目" Grid.Row="5" VerticalAlignment="Center" Margin="0,8" Foreground="#888"/>
        <TextBlock Text="经由帐户" Grid.Row="6" VerticalAlignment="Center" Margin="0,8" Foreground="#888"/>
        <TextBlock Text="经办部门" Grid.Row="7" VerticalAlignment="Center" Margin="0,8" Foreground="#888"/>
        <TextBlock Text="经办人" Grid.Row="8" VerticalAlignment="Center" Margin="0,8" Foreground="#888"/>
        <TextBlock Text="备注" Grid.Row="9" VerticalAlignment="Top" Margin="0,8" Foreground="#888"/>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
            <RadioButton Content="收入"
                         IsChecked="{Binding DataType,Converter={StaticResource sConverter},ConverterParameter=1}"/>
            <RadioButton Content="支出" Margin="10,0"
                         IsChecked="{Binding DataType,Converter={StaticResource sConverter},ConverterParameter=2}"/>
        </StackPanel>

        <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding TypeList}"
                  SelectedItem="{Binding CurrentType}" Height="30"/>

        <DatePicker Grid.Row="2" Grid.Column="1" SelectedDate="{Binding IEInfo.HappendTime}" Height="30"
                    VerticalContentAlignment="Center" Background="White"/>
        <TextBox Grid.Row="3" Grid.Column="1" Style="{DynamicResource ValidationTextBoxStyle}" Height="30"
         Text="{Binding Amount}"/>
        <TextBox Grid.Row="4" Grid.Column="1" Style="{DynamicResource ValidationTextBoxStyle}" Height="30"
                Text="{Binding AmountDesc}"/>
        <TextBox Grid.Row="5" Grid.Column="1" Style="{DynamicResource ValidationTextBoxStyle}" TextWrapping="Wrap"
                 VerticalContentAlignment="Center" Height="30"
                 Text="{Binding IEInfo.ProjectName}"/>
        <TextBox Grid.Row="6" Grid.Column="1" Style="{DynamicResource ValidationTextBoxStyle}" TextWrapping="Wrap"
                 VerticalContentAlignment="Center" Height="30"
                 Text="{Binding IEInfo.Account}"/>
        <TextBox Grid.Row="7" Grid.Column="1" Style="{DynamicResource ValidationTextBoxStyle}" TextWrapping="Wrap"
                 VerticalContentAlignment="Center" Height="30"
                 Text="{Binding IEInfo.Department}"/>
        <TextBox Grid.Row="8" Grid.Column="1" Style="{DynamicResource ValidationTextBoxStyle}" TextWrapping="Wrap"
                 VerticalContentAlignment="Center" Height="30"
                 Text="{Binding IEInfo.Operator}"/>
        <TextBox Grid.Row="9" Grid.Column="1" Style="{DynamicResource ValidationTextBoxStyle}" TextWrapping="Wrap"
                 VerticalContentAlignment="Top" Padding="3,5"
                 Text="{Binding IEInfo.Description}"/>

    </Grid>
</UserControl>
