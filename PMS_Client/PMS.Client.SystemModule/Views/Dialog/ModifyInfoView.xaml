<UserControl x:Class="PMS.Client.SystemModule.Views.Dialog.ModifyInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PMS.Client.SystemModule.Views.Dialog"
             xmlns:c="clr-namespace:PMS.Client.Common;assembly=PMS.Client.Common"
             mc:Ignorable="d" 
             Template="{DynamicResource DialogViewTemplate}"
             Height="450" Width="600">
    <d:UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <FontFamily x:Key="AliFont">/PMS.Client.Assets;component/Fonts/AlibabaPuHuiTi-3-45-Light.ttf#阿里巴巴普惠体 3.0 45 Light</FontFamily>
                    <FontFamily x:Key="DyhFont">/PMS.Client.Assets;component/Fonts/SmileySans-Oblique.ttf#得意黑</FontFamily>
                    <FontFamily x:Key="Iconfont">/PMS.Client.Assets;component/Fonts/iconfont.ttf#zx_icons</FontFamily>

                    <DropShadowEffect Color="#3E7FFF" ShadowDepth="0" Opacity="0.2" x:Key="shadowEffect"/>
                </ResourceDictionary>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ViewTemplates.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ComboBoxStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </d:UserControl.Resources>
    <UserControl.Resources>
        <c:SectionConverter x:Key="sConverter"/>
    </UserControl.Resources>
    <Grid Margin="40,20,40,10" TextBlock.Foreground="#888">
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="35"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="发布标题" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="发布类型" Grid.Row="1" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="关键词" Grid.Row="2" VerticalAlignment="Center" Foreground="#888"/>
        <TextBlock Text="内容" Grid.Row="3" VerticalAlignment="Top" Margin="0,8" Foreground="#888"/>

        <TextBox Grid.Column="1" Style="{DynamicResource ValidationTextBoxStyle}" Height="30"
             Text="{Binding InfoTitle}"/>
        <StackPanel Orientation="Horizontal" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
            <RadioButton Content="公告"
                     IsChecked="{Binding InfoType,Converter={StaticResource sConverter},ConverterParameter=1}"/>
            <RadioButton Content="通知" Margin="10,0"
                     IsChecked="{Binding InfoType,Converter={StaticResource sConverter},ConverterParameter=2}"/>
            <RadioButton Content="新闻"
                     IsChecked="{Binding InfoType,Converter={StaticResource sConverter},ConverterParameter=3}"/>
        </StackPanel>
        <TextBox Grid.Row="2" Grid.Column="1" Style="{DynamicResource ValidationTextBoxStyle}" Height="30"
             Text="{Binding Key}"/>
        <TextBox Grid.Row="3" Grid.Column="1" Style="{DynamicResource ValidationTextBoxStyle}" TextWrapping="Wrap" Margin="0,5"
             VerticalContentAlignment="Top" Padding="5,5"
             Text="{Binding Content}"/>

    </Grid>
</UserControl>
