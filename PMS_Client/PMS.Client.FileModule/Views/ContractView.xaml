<UserControl x:Class="PMS.Client.FileModule.Views.ContractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PMS.Client.FileModule.Views"
             xmlns:zxc="clr-namespace:PMS.Client.Controls;assembly=PMS.Client.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000">
    <d:UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ButtonStyles.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/TextBoxStyles.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ViewTemplates.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ComboBoxStyle.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/ScrollViewerStyle.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/CollectionStyles.xaml"/>
                <ResourceDictionary Source="/PMS.Client.Assets;component/Styles/DatePickerStyle.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <FontFamily x:Key="AliFont">/PMS.Client.Assets;component/Fonts/AlibabaPuHuiTi-3-45-Light.ttf#阿里巴巴普惠体 3.0 45 Light</FontFamily>
            <FontFamily x:Key="DyhFont">/PMS.Client.Assets;component/Fonts/SmileySans-Oblique.ttf#得意黑</FontFamily>
            <FontFamily x:Key="Iconfont">/PMS.Client.Assets;component/Fonts/iconfont.ttf#zx_icons</FontFamily>

            <DropShadowEffect Color="#3E7FFF" ShadowDepth="0" Opacity="0.2" x:Key="shadowEffect"/>


        </ResourceDictionary>
    </d:UserControl.Resources>
    <Grid Background="#F4F7FF">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="70"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <TextBlock Text="| 物业 > 文件 " VerticalAlignment="Center" Margin="10,5,0,0" Foreground="#999"/>

        <Border CornerRadius="5" Grid.Row="1" Grid.RowSpan="3" Margin="5">
            <Border.Effect>
                <DropShadowEffect Color="#DDD" ShadowDepth="2"
                          BlurRadius="5" Direction="-90" Opacity="0.2"/>
            </Border.Effect>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#EFEFEF" Offset="0"/>
                    <GradientStop Color="White" Offset="0.2"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>
        <Border Grid.Row="2" Margin="5,0"
        BorderBrush="#DEDEDE" BorderThickness="0,1"/>


        <!--搜索输入框-->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="1"
                Orientation="Horizontal" Margin="280,0">
            <TextBlock Text="账款发生日期" Foreground="#888" VerticalAlignment="Center"/>
            <DatePicker Height="30" VerticalContentAlignment="Center" Margin="10,0"
                    Width="120" DisplayDateEnd="{Binding EndDate}"
                    SelectedDate="{Binding StartDate}"/>
            <TextBlock Text="-" VerticalAlignment="Center"/>
            <DatePicker Height="30" VerticalContentAlignment="Center" Margin="10,0"
                    Width="120" DisplayDateStart="{Binding StartDate}"
                    SelectedDate="{Binding EndDate}"/>
        </StackPanel>

        <TextBlock Text="检索" Grid.Row="1" VerticalAlignment="Center" Margin="20,0" 
                HorizontalAlignment="Left" Foreground="#888"/>
        <TextBox VerticalAlignment="Center" Width="200" HorizontalAlignment="Left" Grid.Row="1"
             Text="{Binding SearchKey,UpdateSourceTrigger=PropertyChanged}" Margin="60,0,0,0"
             Style="{DynamicResource SearchTextBoxStyle}" Name="tb_search">
            <TextBox.InputBindings>
                <KeyBinding Key="Return" Command="{Binding RefreshCommand}"/>
            </TextBox.InputBindings>
        </TextBox>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right"
                Grid.Row="1" Margin="20,0">
            <!--刷新按钮-->
            <Button Content="刷新" Style="{DynamicResource NormalButtonStyle}" Foreground="White"
                Command="{Binding RefreshCommand}"
                Width="60" Margin="5,0"/>
            <!--添加按钮-->
            <Button Content="新建" Style="{DynamicResource IconWithContentButtonStyle}"
                Command="{Binding ModifyCommand}"
                Tag="&#xe603;" Width="80">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#FE582D" Offset="0"/>
                        <GradientStop Color="#F1961A" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </StackPanel>

        <Grid Grid.IsSharedSizeScope="True" Margin="5,5,5,10" Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Border Background="#EEE" Height="1" VerticalAlignment="Bottom"/>

            <Grid TextBlock.FontSize="12" TextBlock.FontWeight="Bold" TextBlock.Foreground="#666">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="序号" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="合同编号" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="合同名称" Grid.Column="2" VerticalAlignment="Center" Margin="5,0"/>
                <TextBlock Text="合同金额" Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="5,0"/>
                <TextBlock Text="签约时间" Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="对方单位" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="经办人" Grid.Column="6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="执行金额" Grid.Column="7" VerticalAlignment="Center" Margin="5,0"/>
                <TextBlock Text="执行进度" Grid.Column="8" VerticalAlignment="Center" Margin="5,0"/>
                <TextBlock Text="状态" Grid.Column="9" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="归档时间" Grid.Column="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="归档人" Grid.Column="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <TextBlock Text="操作" Grid.Column="12" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <!--编辑、分配权限、重置密码、删除-->
            </Grid>

            <ListBox ItemsSource="{Binding ContractList}" Grid.Row="1" 
                 BorderThickness="0" Background="Transparent"
                 ItemContainerStyle="{DynamicResource NoramalListBoxItemStyle}">

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Background="Transparent" Name="root" Height="30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="30"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <!--间隔线-->
                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Height="1" VerticalAlignment="Bottom" Grid.ColumnSpan="20" SnapsToDevicePixels="True"/>

                            <!--序号-->
                            <TextBlock Text="{Binding Index}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Foreground="#888"/>

                            <TextBlock Text="{Binding ContractNumber}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="#555" Grid.Column="1"/>

                            <TextBlock Text="{Binding ContractName}" VerticalAlignment="Center"
                                   TextTrimming="WordEllipsis" ToolTip="{Binding ContractName}"
                                   FontWeight="Bold" Foreground="#333" Grid.Column="2" Margin="5,0"/>

                            <TextBlock Text="{Binding ContrackAmount}" VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Foreground="#555" Grid.Column="3" Margin="5,0"/>

                            <TextBlock Text="{Binding SignTime,StringFormat=yyyy-MM-dd}" FontSize="12" Foreground="#888" 
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Grid.Column="4"/>
                            <TextBlock Text="{Binding Opposite}" FontSize="12" Foreground="#888" 
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Grid.Column="5"/>
                            <TextBlock Text="{Binding Operator}" FontSize="12" Foreground="#888" 
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Grid.Column="6"/>
                            <TextBlock Text="{Binding ExcuteAmount}" VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Foreground="#555" Grid.Column="7" Margin="5,0"/>
                            <ProgressBar Grid.Column="8" Value="{Binding Prograss}" Minimum="0" Maximum="1"
                                     Height="10" Margin="3,0" BorderThickness="0"/>

                            <!--状态-->
                            <Border VerticalAlignment="Center"  HorizontalAlignment="Center" Grid.Column="9"
                                Width="38" Height="18" CornerRadius="9" Name="bor_type" Background="Gray">
                                <TextBlock Text="创建" VerticalAlignment="Center" Foreground="White" FontSize="10"
                                HorizontalAlignment="Center" Name="tb_status"/>
                            </Border>

                            <TextBlock Text="{Binding ArchivedTime,StringFormat=yyyy-MM-dd}" Grid.Column="10" Foreground="#888"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>
                            <TextBlock Text="{Binding ArchivedUserName}" Grid.Column="11" Foreground="#888"
                                    VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12"/>

                            <!--操作-->
                            <StackPanel Grid.Column="12" VerticalAlignment="Center" 
                            HorizontalAlignment="Center"
                            Orientation="Horizontal">
                                <TextBlock VerticalAlignment="Center" Name="tb_execute" Margin="3,0">
                                <Hyperlink Command="{Binding DataContext.ExecuteCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           TextDecorations="None" Foreground="#409EFE">执行</Hyperlink>
                                </TextBlock>
                                <TextBlock VerticalAlignment="Center" Name="tb_cancel" Margin="3,0">
                                <Hyperlink Command="{Binding DataContext.RevokeCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           TextDecorations="None" Foreground="#409EFE">撤销</Hyperlink>
                                </TextBlock>
                                <TextBlock VerticalAlignment="Center" Name="tb_approve" Margin="3,0">
                                <Hyperlink Command="{Binding DataContext.ApproveCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           TextDecorations="None" Foreground="#409EFE">审批</Hyperlink>
                                </TextBlock>
                                <TextBlock VerticalAlignment="Center" Margin="3,0" Name="tb_edit">
                                <Hyperlink Command="{Binding DataContext.ModifyCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           TextDecorations="None" Foreground="#409EFE">编辑</Hyperlink>
                                </TextBlock>
                                <TextBlock VerticalAlignment="Center" Margin="3,0" Name="tb_delete">
                                <Hyperlink Command="{Binding DataContext.DeleteCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           TextDecorations="None" Foreground="#409EFE">删除</Hyperlink>
                                </TextBlock>
                                <TextBlock VerticalAlignment="Center" Margin="3,0" Name="tb_archived">
                                <Hyperlink Command="{Binding DataContext.ArchivedCommand,RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           TextDecorations="None" Foreground="#409EFE">建档</Hyperlink>
                                </TextBlock>
                            </StackPanel>

                        </Grid>
                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="#F7F9FA"/>
                            </Trigger>

                            <DataTrigger Binding="{Binding State}" Value="0">
                                <Setter TargetName="tb_status" Property="Text" Value="创建"/>
                                <Setter TargetName="bor_type" Property="Background" Value="#DDD"/>
                                <Setter TargetName="tb_execute" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_cancel" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_approve" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="tb_edit" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="tb_delete" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="tb_archived" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="1">
                                <Setter TargetName="tb_status" Property="Text" Value="已审批"/>
                                <Setter TargetName="bor_type" Property="Background" Value="#409EFE"/>
                                <Setter TargetName="tb_execute" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="tb_cancel" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="tb_approve" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_edit" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_delete" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_archived" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="2">
                                <Setter TargetName="tb_status" Property="Text" Value="完结"/>
                                <Setter TargetName="bor_type" Property="Background" Value="orange"/>
                                <Setter TargetName="tb_execute" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_cancel" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_approve" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_edit" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_delete" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_archived" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="3">
                                <Setter TargetName="tb_status" Property="Text" Value="已建档"/>
                                <Setter TargetName="bor_type" Property="Background" Value="ForestGreen"/>
                                <Setter TargetName="tb_execute" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_cancel" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_approve" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_edit" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_delete" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="tb_archived" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>

        <zxc:Pagination HorizontalAlignment="Center" VerticalAlignment="Center"
            Grid.Row="3" DataContext="{Binding PaginationModel}"/>
    </Grid>
</UserControl>
